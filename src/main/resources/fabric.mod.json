{
  "schemaVersion": 1,
  "id": "scoutreloaded",
  "version": "${version}",

  "name": "ScoutReloaded",
  "description": "A mod focused on \"physically\" extending the inventory (adding slots) through wearing various types of bags.",
  "authors": [
    "Cynosphere",
    "UTMG"
  ],
  "contact": {
    "sources": "https://github.com/UntitledModGroup/Scout-Mod"
  },

  "license": "MIT",
  "icon": "assets/scout/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "pm.c7.scout.Scout"
    ],
    "client": [
      "pm.c7.scout.ScoutClient"
    ],
    "emi": [
      "pm.c7.scout.compat.ScoutEmiPlugin"
    ]
  },
  "mixins": [
    "scout.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "trinkets": ">=3.10.0"
  },

  "breaks": {
    "infinitory": "*",
    "biginv": "*",
    "extrainv": "*"
  }
}
